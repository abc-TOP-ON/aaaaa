local function showNotification(text, color)
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 180, 0, 20)
    notif.Position = UDim2.new(0.5, -90, 0.60, 0)
    notif.Text = "▸ " .. text
    notif.TextColor3 = color or Color3.fromRGB(138, 43, 226)
    notif.TextSize = 9
    notif.Font = Enum.Font.Gotham
    notif.BackgroundColor3 = Color3.fromRGB(10, 8, 20)
    notif.BackgroundTransparency = 0.3
    notif.Parent = Background
    
    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 6)
    notifCorner.Parent = notif
    
    local notifStroke = Instance.new("UIStroke")
    notifStroke.Color = color or Color3.fromRGB(138, 43, 226)
    notifStroke.Thickness = 1
    notifStroke.Transparency = 0.5
    notifStroke.Parent = notif
    
    notif.Position = UDim2.new(0.5, -90, 0.63, 0)
    notif.TextTransparency = 1
    
    local appear = TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, -90, 0.60, 0),
        TextTransparency = 0
    })
    appear:Play()
    
    task.wait(1.8)
    
    local disappear = TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        TextTransparency = 1,
        Position = UDim2.new(0.5, -90, 0.63, 0)
    })
    disappear:Play()
    disappear.Completed:Connect(function() notif:Destroy() end)
end

