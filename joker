local function createHeaderButton(parent, icon, position, color, tooltip, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 40, 0, 40)
    btn.Position = position
    btn.BackgroundColor3 = color
    btn.BackgroundTransparency = 0.8
    btn.Text = icon
    btn.TextColor3 = DESIGN.Text
    btn.TextSize = 18
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(1, 0)
    btnCorner.Parent = btn
    
    -- Hover Effect
    btn.MouseEnter:Connect(function()
        tweenObject(btn, {
            BackgroundTransparency = 0.3,
            Size = UDim2.new(0, 44, 0, 44),
            Position = position + UDim2.new(0, -2, 0, -2),
        }, 0.15)
    end)
    
    btn.MouseLeave:Connect(function()
        tweenObject(btn, {
            BackgroundTransparency = 0.8,
            Size = UDim2.new(0, 40, 0, 40),
            Position = position,
        }, 0.15)
    end)
    
    -- Click Animation
    btn.MouseButton1Click:Connect(function()
        tweenObject(btn, {
            Size = UDim2.new(0, 35, 0, 35),
        }, 0.1)
        task.wait(0.1)
        tweenObject(btn, {
            Size = UDim2.new(0, 40, 0, 40),
        }, 0.1)
        callback()
    end)
    
    -- Tooltip
    local tooltipObj = Instance.new("TextLabel")
    tooltipObj.Size = UDim2.new(0, 80, 0, 25)
    tooltipObj.Position = UDim2.new(0.5, -40, 1, 5)
    tooltipObj.BackgroundColor3 = DESIGN.Surface2
    tooltipObj.BackgroundTransparency = 0.2
    tooltipObj.Text = tooltip
    tooltipObj.TextColor3 = DESIGN.Text2
    tooltipObj.TextSize = 10
    tooltipObj.Font = Enum.Font.Gotham
    tooltipObj.Visible = false
    tooltipObj.Parent = btn
    
    local tooltipCorner = Instance.new("UICorner")
    tooltipCorner.CornerRadius = UDim.new(0, 6)
    tooltipCorner.Parent = tooltipObj
    
    btn.MouseEnter:Connect(function()
        tooltipObj.Visible = true
    end)
    
    btn.MouseLeave:Connect(function()
        tooltipObj.Visible = false
    end)
    
    return btn
end

