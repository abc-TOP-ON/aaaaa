local ColorCache = {}
local function getPlayerColor(playerName)
    if ColorCache[playerName] then
        return ColorCache[playerName]
    end
    
    local hue = math.random()
    local color = Color3.fromHSV(hue, 0.7, 0.8)
    ColorCache[playerName] = color
    return color
end

-- ================================================================
--                    OPTIMIZED UTILITY FUNCTIONS
-- ================================================================
local function fastStringFind(text, pattern)
    return string.find(string.lower(text), string.lower(pattern), 1, true)
end

local function isFiltered(message)
    for i = 1, #Settings.FilteredWords do
        if fastStringFind(message, Settings.FilteredWords[i]) then
            return true
        end
    end
    return false
end

local function isBadWord(message)
    if not Settings.BadWordFilter then return false end
    for i = 1, #Settings.BadWords do
        if fastStringFind(message, Settings.BadWords[i]) then
            return true
        end
    end
    return false
end

local function containsLink(message)
    return fastStringFind(message, "http") or 
           fastStringFind(message, ".com") or
           fastStringFind(message, ".net")
end

local function containsCrypto(message)
    local crypto = {"bitcoin", "btc", "ethereum", "eth", "dogecoin", "doge", "wallet"}
    for i = 1, #crypto do
        if fastStringFind(message, crypto[i]) then
            return true
        end
    end
    return false
end

local function containsMention(message)
    return fastStringFind(message, Settings.MyName)
end

-- ================================================================
--                    EFFICIENT AVATAR LOADING
-- ================================================================
local AvatarCache = {}
local function getPlayerAvatar(player)
    local userId = player.UserId
    if AvatarCache[userId] then
        return AvatarCache[userId]
    end
    
    local success, thumbnail = pcall(function()
        return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
    end)
    
    if success and thumbnail then
        AvatarCache[userId] = thumbnail
        if #AvatarCache > PERFORMANCE.CACHE_SIZE then
            -- Clear old cache entries
            local keys = {}
            for k in pairs(AvatarCache) do
                table.insert(keys, k)
            end
            for i = 1, #keys - PERFORMANCE.CACHE_SIZE do
                AvatarCache[keys[i]] = nil
            end
        end
        return thumbnail
    end
    return "rbxasset://textures/ui/GuiImagePlaceholder.png"
end

