local renderQueue = {}
local isRendering = false
local visibleMessages = {}
local messageCount = 0

function renderAllMessages()
    -- Clear existing messages
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local startIndex = 1
    if Settings.MaxMessages > 0 and #Cache.Messages > Settings.MaxMessages then
        startIndex = #Cache.Messages - Settings.MaxMessages + 1
    end
    
    local count = 0
    for i = startIndex, #Cache.Messages do
        local data = Cache.Messages[i]
        if not isFiltered(data.message) and not (Settings.BadWordFilter and isBadWord(data.message)) then
            local frame = createMessageUI(data.player, data.message, false)
            frame.Parent = ScrollingFrame
            count = count + 1
        end
    end
    
    messageCount = count
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

