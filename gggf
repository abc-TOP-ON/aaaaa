local function addMessageToGui(sender, messageText, channelTag)
    channelTag = channelTag or "GLOBAL"
    local tagColor = "rgb(138, 43, 226)"
    
    if channelTag == "WHISPER" then tagColor = "rgb(255, 0, 255)"
    elseif channelTag == "TEAM" then tagColor = "rgb(30, 144, 255)"
    elseif channelTag == "SYSTEM" then tagColor = "rgb(255, 215, 0)" end
    
    -- الحاوية الرئيسية للرسالة
    local MessageContainer = Instance.new("Frame")
    MessageContainer.Size = UDim2.new(1, -5, 0, 40)
    MessageContainer.BackgroundTransparency = 1
    MessageContainer.Parent = ScrollingFrame
    
    -- صورة اللاعب
    local AvatarImage = Instance.new("ImageLabel")
    AvatarImage.Size = UDim2.new(0, 30, 0, 30)
    AvatarImage.Position = UDim2.new(0, 2, 0, 5)
    AvatarImage.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    AvatarImage.BorderSizePixel = 0
    AvatarImage.Parent = MessageContainer
    
    local AvatarCorner = Instance.new("UICorner")
    AvatarCorner.CornerRadius = UDim.new(1, 0)
    AvatarCorner.Parent = AvatarImage
    
    local AvatarStroke = Instance.new("UIStroke")
    AvatarStroke.Color = Color3.fromRGB(138, 43, 226)
    AvatarStroke.Thickness = 1.5
    AvatarStroke.Parent = AvatarImage
    
    -- جلب صورة اللاعب
    if sender and sender.UserId then
        local avatarUrl = getPlayerAvatar(sender.UserId)
        AvatarImage.Image = avatarUrl
    else
        AvatarImage.Image = "rbxassetid://0"
    end
    
    -- اسم اللاعب + الرسالة
    local MessageText = Instance.new("TextLabel")
    MessageText.Size = UDim2.new(1, -40, 1, 0)
    MessageText.Position = UDim2.new(0, 38, 0, 0)
    MessageText.BackgroundTransparency = 1
    MessageText.RichText = true
    
    local senderName = sender and sender.DisplayName or "Unknown"
    local nameColor = tagColor
    
    if channelTag == "WHISPER" then
        nameColor = "rgb(255, 0, 255)"
    elseif channelTag == "TEAM" then
        nameColor = "rgb(30, 144, 255)"
    elseif channelTag == "SYSTEM" then
        nameColor = "rgb(255, 215, 0)"
    end
    
    -- تنسيق مثل الديسكورد
    MessageText.Text = string.format("<font color='%s'><b>[%s] %s:</b></font> %s", nameColor, channelTag, senderName, messageText)
    MessageText.TextColor3 = Color3.fromRGB(230, 230, 240)
    MessageText.TextSize = 13
    MessageText.Font = Enum.Font.SourceSans
    MessageText.TextXAlignment = Enum.TextXAlignment.Left
    MessageText.TextWrapped = true
    MessageText.TextYAlignment = Enum.TextYAlignment.Center
    MessageText.Parent = MessageContainer
    
    -- تحديث الحجم حسب النص
    MessageContainer.Size = UDim2.new(1, -5, 0, 40)
    MessageText.Size = UDim2.new(1, -40, 1, 0)
    
    -- وظيفة البحث والفلترة
    local function applyFilter()
        local filterText = string.lower(SearchBox.Text)
        if filterText == "" or string.find(string.lower(senderName), filterText) or string.find(string.lower(messageText), filterText) then
            MessageContainer.Visible = true
        else
            MessageContainer.Visible = false
        end
    end
    
    SearchBox.GetPropertyChangedSignal(SearchBox, "Text"):Connect(applyFilter)
    applyFilter()
    
    -- تحديث الـ Canvas مع منع النزول التلقائي
