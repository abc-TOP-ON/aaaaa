function displayAllMessages()
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local startIndex = 1
    if Settings.MaxMessages > 0 and #AllMessages > Settings.MaxMessages then
        startIndex = #AllMessages - Settings.MaxMessages + 1
    end
    
    for i = startIndex, #AllMessages do
        local data = AllMessages[i]
        if not isFiltered(data.message) and not (Settings.BadWordFilter and isBadWord(data.message)) then
            local newFrame = data.frame:Clone()
            newFrame.Parent = ScrollingFrame
            newFrame.BackgroundTransparency = 1
        end
    end
    
    task.wait(0.1)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

local function addMessageToGui(sender, messageText, isSearchResult)
    -- Filters
    if isFiltered(messageText) then return end
    if Settings.BadWordFilter and isBadWord(messageText) then return end
    if sender == LocalPlayer and not Settings.ShowMyMessages then return end
    
    -- Hibernation check
    if Settings.Hibernation then
        lastMessageTime = tick()
        if isHibernating then
            isHibernating = false
            MainFrame.Visible = true
            addSystemMessage("💤 Waking up from hibernation!")
        end
    end
    
    -- Preview
    if Settings.PreviewEnabled and containsLink(messageText) then
        addSystemMessage("🔗 Link detected from " .. sender.Name .. ": " .. messageText)
    end
    
    -- Crypto detection
    if Settings.CryptoScamDetection and containsCrypto(messageText) then
        addSystemMessage("🚨 CRYPTO SCAM ALERT: " .. sender.Name .. " sent suspicious message!")
    end
    
    -- Link alert
    if Settings.LinkAlert and containsLink(messageText) then
        addSystemMessage("⚠️ Link from " .. sender.Name .. ": " .. messageText)
    end
    
    -- Mention alert
    if Settings.MentionAlert and containsMention(messageText) and sender ~= LocalPlayer then
        for i = 1, 3 do
            MainFrame.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            task.wait(0.1)
            MainFrame.BackgroundColor3 = Settings.DarkMode and Color3.fromRGB(20, 20, 30) or Color3.fromRGB(240, 240, 245)
            task.wait(0.1)
        end
        playSound()
        addSystemMessage("🔔 " .. sender.Name .. " mentioned you!")
    end
    
    -- Update stats
    updateStats(sender, messageText)
    
    -- Update chat map
    local target = string.match(messageText, "@(%w+)")
    if target then
        updateChatMap(sender, target)
    end
    
    -- Detect patterns
    detectPattern(sender, messageText)
    
    -- Detect emotion
    detectEmotion(messageText)
    
    -- Auto reply
    if sender ~= LocalPlayer then
        handleAutoReply(sender, messageText)
        handleAIAssistant(sender, messageText)
    end
    
    -- Translation (just for display)
    local displayText = messageText
    if Settings.VoiceTranslation then
        displayText = translateMessage(messageText)
    end
    
    -- Create message UI
    local MessageFrame = Instance.new("Frame")
    MessageFrame.Size = UDim2.new(1, -10, 0, 50)
    MessageFrame.BackgroundTransparency = 1
    MessageFrame.Parent = ScrollingFrame
    
    local avatarImage = createAvatarImage(sender)
    avatarImage.Position = UDim2.new(0, 5, 0, 5)
    avatarImage.Parent = MessageFrame
    
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size = UDim2.new(0.8, 0, 0, 20)
    NameLabel.Position = UDim2.new(0, 50, 0, 2)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = (sender.DisplayName or sender.Name)
    NameLabel.TextColor3 = getPlayerColor(sender.Name)
    NameLabel.TextSize = 14
    NameLabel.Font = Enum.Font.SourceSansBold
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
    NameLabel.Parent = MessageFrame
    
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(0.8, 0, 0, 24)
    TextLabel.Position = UDim2.new(0, 50, 0, 22)
    TextLabel.BackgroundTransparency = 1
    TextLabel.Text = displayText
    TextLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
    TextLabel.TextSize = Settings.FontSize
    TextLabel.Font = Enum.Font.SourceSans
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.TextWrapped = true
    TextLabel.Parent = MessageFrame
    
    if isSearchResult then
        MessageFrame.BackgroundColor3 = Color3.fromRGB(60, 40, 40)
        MessageFrame.BackgroundTransparency = 0.3
        local highlightCorner = Instance.new("UICorner")
        highlightCorner.CornerRadius = UDim.new(0, 8)
        highlightCorner.Parent = MessageFrame
    end
    
    if not isSearchResult then
        table.insert(AllMessages, {
            player = sender,
            message = messageText,
            frame = MessageFrame:Clone()
        })
        
        if Settings.MaxMessages > 0 and #AllMessages > Settings.MaxMessages then
            table.remove(AllMessages, 1)
        end
    end
    
    -- Sound
    if sender ~= LocalPlayer then
        playSound()
    end
    
    -- Notification
    if sender ~= LocalPlayer then
        showNotification(sender, messageText)
    end
    
    -- Update scroll
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
    ScrollingFrame.CanvasPosition = Vector2.new(0, ScrollingFrame.CanvasSize.Y.Offset)
end

