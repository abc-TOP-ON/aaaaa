-- ================================================================
--                    OBJECT POOL (UI Reuse)
-- ================================================================
local ObjectPool = {
    MessageFrames = {},
    TextLabels = {},
    ImageLabels = {},
}

local function getFromPool(poolName, createFn)
    local pool = ObjectPool[poolName]
    if #pool > 0 then
        local obj = table.remove(pool)
        obj.Visible = true
        return obj
    end
    return createFn()
end

local function returnToPool(poolName, obj)
    obj.Visible = false
    obj.Parent = nil
    table.insert(ObjectPool[poolName], obj)
end

