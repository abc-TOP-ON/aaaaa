    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and settings.dragEnabled then
        dragToggle2 = true
        dragStart2 = input.Position
        startPos2 = ABCToggle.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragToggle2 = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle2 then
        local deltaX = (input.Position - dragStart2).X
        local deltaY = (input.Position - dragStart2).Y
        ABCToggle.Position = UDim2.new(startPos2.X.Scale, startPos2.X.Offset + deltaX, startPos2.Y.Scale, startPos2.Y.Offset + deltaY)
    end
end)

