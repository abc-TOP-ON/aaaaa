local function createHeaderButton(parent, icon, position, color, tooltip, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 50, 0, 50) -- Bigger for mobile
    btn.Position = position
    btn.BackgroundColor3 = color
    btn.BackgroundTransparency = 0.5
    btn.Text = icon
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 22 -- Bigger text for mobile
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(1, 0)
    btnCorner.Parent = btn
    
    -- Tooltip
    local tooltipObj = Instance.new("TextLabel")
    tooltipObj.Size = UDim2.new(0, 100, 0, 30)
    tooltipObj.Position = UDim2.new(0.5, -50, 1, 5)
    tooltipObj.BackgroundColor3 = Color3.fromRGB(45, 50, 65)
    tooltipObj.BackgroundTransparency = 0.2
    tooltipObj.Text = tooltip
    tooltipObj.TextColor3 = Color3.fromRGB(180, 180, 200)
    tooltipObj.TextSize = 12
    tooltipObj.Font = Enum.Font.Gotham
    tooltipObj.Visible = false
    tooltipObj.Parent = btn
    
    local tooltipCorner = Instance.new("UICorner")
    tooltipCorner.CornerRadius = UDim.new(0, 8)
    tooltipCorner.Parent = tooltipObj
    
    btn.MouseEnter:Connect(function()
        tweenObject(btn, {
            BackgroundTransparency = 0.2,
            Size = UDim2.new(0, 55, 0, 55),
            Position = position + UDim2.new(0, -2.5, 0, -2.5),
        }, 0.15)
        tooltipObj.Visible = true
    end)
    
    btn.MouseLeave:Connect(function()
        tweenObject(btn, {
            BackgroundTransparency = 0.5,
            Size = UDim2.new(0, 50, 0, 50),
            Position = position,
        }, 0.15)
        tooltipObj.Visible = false
    end)
    
    -- Click animation
    btn.MouseButton1Click:Connect(function()
        tweenObject(btn, {
            Size = UDim2.new(0, 45, 0, 45),
        }, 0.1)
        task.wait(0.1)
        tweenObject(btn, {
            Size = UDim2.new(0, 50, 0, 50),
        }, 0.1)
        callback()
    end)
    
    -- Touch support for mobile
    btn.TouchEnded:Connect(function()
        tweenObject(btn, {
            Size = UDim2.new(0, 45, 0, 45),
        }, 0.1)
        task.wait(0.1)
        tweenObject(btn, {
            Size = UDim2.new(0, 50, 0, 50),
        }, 0.1)
        callback()
    end)
    
    return btn
end

