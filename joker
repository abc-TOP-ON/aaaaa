local function getPlayerColor(playerName)
    if Cache.Colors[playerName] then
        return Cache.Colors[playerName]
    end
    
    local colors = {
        Color3.fromRGB(255, 107, 107),  -- Red
        Color3.fromRGB(78, 205, 196),   -- Teal
        Color3.fromRGB(255, 159, 67),   -- Orange
        Color3.fromRGB(255, 235, 59),   -- Yellow
        Color3.fromRGB(130, 177, 255),  -- Light Blue
        Color3.fromRGB(206, 147, 216),  -- Purple
        Color3.fromRGB(255, 138, 101),  -- Coral
        Color3.fromRGB(100, 255, 218),  -- Mint
        Color3.fromRGB(255, 204, 128),  -- Peach
        Color3.fromRGB(200, 200, 255),  -- Lavender
    }
    
    local index = #Cache.Colors % #colors + 1
    local color = colors[index]
    Cache.Colors[playerName] = color
    return color
end

local function fastStringFind(text, pattern)
    return string.find(string.lower(text), string.lower(pattern), 1, true)
end

local function isFiltered(message)
    for i = 1, #Settings.FilteredWords do
        if fastStringFind(message, Settings.FilteredWords[i]) then
            return true
        end
    end
    return false
end

local function isBadWord(message)
    if not Settings.BadWordFilter then return false end
    for i = 1, #Settings.BadWords do
        if fastStringFind(message, Settings.BadWords[i]) then
            return true
        end
    end
    return false
end

local function containsLink(message)
    return fastStringFind(message, "http") or 
           fastStringFind(message, ".com") or
           fastStringFind(message, ".net")
end

local function containsCrypto(message)
    local crypto = {"bitcoin", "btc", "ethereum", "eth", "dogecoin", "doge", "wallet"}
    for i = 1, #crypto do
        if fastStringFind(message, crypto[i]) then
            return true
        end
    end
    return false
end

local function containsMention(message)
    return fastStringFind(message, Settings.MyName)
end

