task.wait(0.8)

-- =====================================================
-- [الإصلاح النهائي]: إخفاء الواجهة بشكل مضمون 100%
-- =====================================================
local function destroyScreen()
    -- إيقاف جميع العمليات
    task.cancel(particleLoop)
    
    -- تنظيف الجزيئات
    for _, p in pairs(particles) do
        p:Destroy()
    end
    particles = {}
    
    -- إخفاء جميع العناصر مع تأثير
    local fadeInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    
    for _, item in pairs(Background:GetChildren()) do
        task.spawn(function()
            if item:IsA("TextLabel") then
                pcall(function()
                    TweenService:Create(item, fadeInfo, {TextTransparency = 1}):Play()
                end)
            elseif item:IsA("ImageLabel") then
                pcall(function()
                    TweenService:Create(item, fadeInfo, {ImageTransparency = 1}):Play()
                end)
            elseif item:IsA("Frame") and item ~= Background then
                pcall(function()
                    TweenService:Create(item, fadeInfo, {BackgroundTransparency = 1}):Play()
                end)
            end
            
            local stroke = item:FindFirstChildOfClass("UIStroke")
            if stroke then
                pcall(function()
                    TweenService:Create(stroke, fadeInfo, {Transparency = 1}):Play()
                end)
            end
        end)
    end
    
    -- إخفاء الخلفية
    local fadeBackground = TweenService:Create(Background, fadeInfo, {BackgroundTransparency = 1})
    fadeBackground:Play()
    fadeBackground.Completed:Wait()
    
    -- حذف الواجهة بالكامل
    pcall(function()
        ScreenGui:Destroy()
    end)
    
    print("✅ ABC Premium Ultra Screen Destroyed Successfully!")
end

-- تنفيذ الإخفاء
destroyScreen()

-- =====================================================
-- نظام حماية: منع الإلغاء الخاطئ
-- =====================================================
local cancelAttempts = 0
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Escape then
        if not isLoadingComplete then
            cancelAttempts = cancelAttempts + 1
            if cancelAttempts >= 3 then
                -- إلغاء التحميل بعد 3 محاولات
                isLoadingComplete = true
                task.cancel(particleLoop)
                pcall(function() ScreenGui:Destroy() end)
                print("⏹ Loading cancelled by user (3 attempts)")
            else
                showAdvancedNotification("Press ESC " .. (3 - cancelAttempts) .. " more times to cancel", "⚠️", Color3.fromRGB(255, 200, 50))
            end
        end
    end
end)

print("🚀 ABC Premium Ultra 100× Loading Screen Loaded!")
