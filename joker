-- ============================================
-- Deep Packet Capture Core
-- ============================================
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(textMessage)
        local source = textMessage.TextSource
        if source then
            local sender = Players:GetPlayerByUserId(source.UserId)
            if sender then
                local channel = "GLOBAL"
                if textMessage.TextChannel and string.find(string.lower(textMessage.TextChannel.Name), "whisper") then
                    channel = "WHISPER"
                elseif textMessage.TextChannel and string.find(string.lower(textMessage.TextChannel.Name), "team") then
                    channel = "TEAM"
                end
                addMessageToGui(sender, textMessage.Text, channel)
            end
        end
    end)
else
    local SayMessageEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("OnMessageDoneFiltering")
    if SayMessageEvent and SayMessageEvent:IsA("RemoteEvent") then
        SayMessageEvent.OnClientEvent:Connect(function(messageData)
            if messageData then
                local sender = messageData.FromPlayer
                local message = messageData.Message
                local channel = "GLOBAL"
                
                if messageData.MessageType == "Whisper" then channel = "WHISPER"
                elseif messageData.MessageType == "Team" then channel = "TEAM" end
                
                if sender and message then
                    local player = Players:GetPlayerByUserId(sender)
                    if player then
                        addMessageToGui(player, message, channel)
                    end
                end
            end
        end)
    else
        local function hookPlayer(player)
            player.Chatted:Connect(function(message)
                addMessageToGui(player, message, "GLOBAL")
            end)
        end
        for _, player in ipairs(Players:GetPlayers()) do hookPlayer(player) end
        Players.PlayerAdded:Connect(hookPlayer)
    end
end

-- ============================================
-- وظيفة حفظ المحادثة
-- ============================================
local function saveCurrentChat()
    local messages = {}
    local count = 0
    
    for _, child in pairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            local textLabel = child:FindFirstChildOfClass("TextLabel")
            if textLabel and textLabel.RichText then
                local rawText = textLabel.Text
                rawText = rawText:gsub("<[^>]*>", "")
                messages[#messages + 1] = rawText
                count = count + 1
            end
        end
    end
    
    if count == 0 then
        addMessageToGui(nil, "No messages to save!", "SYSTEM")
        return
    end
    
    local fullLog = "=== ABC Spy Pro Chat Log ===\n"
    fullLog = fullLog .. "Date: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n"
    fullLog = fullLog .. "Total Messages: " .. count .. "\n"
    fullLog = fullLog .. "===============================\n\n"
    
    for i, msg in ipairs(messages) do
        fullLog = fullLog .. msg .. "\n"
    end
    
    savedChatsCount = savedChatsCount + 1
    local saveName = "Chat #" .. savedChatsCount .. " (" .. os.date("%H:%M") .. ")"
    savedChats[saveName] = fullLog
    stats.savedCount = stats.savedCount + 1
    
    local savedItem = Instance.new("TextButton")
    savedItem.Size = UDim2.new(1, -10, 0, 30)
    savedItem.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    savedItem.Text = saveName .. " (" .. count .. " messages)"
    savedItem.TextColor3 = Color3.fromRGB(200, 200, 220)
    savedItem.TextSize = 13
    savedItem.Font = Enum.Font.Gotham
    savedItem.TextXAlignment = Enum.TextXAlignment.Left
    savedItem.Parent = SavedScrollingFrame
    
    local savedItemCorner = Instance.new("UICorner")
    savedItemCorner.CornerRadius = UDim.new(0, 6)
    savedItemCorner.Parent = savedItem
    
    local deleteBtn = Instance.new("TextButton")
    deleteBtn.Size = UDim2.new(0, 25, 0, 25)
    deleteBtn.Position = UDim2.new(0.92, 0, 0.025, 0)
    deleteBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
    deleteBtn.Text = "✕"
    deleteBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    deleteBtn.Font = Enum.Font.GothamBold
    deleteBtn.TextSize = 13
    deleteBtn.Parent = savedItem
    
    local deleteCorner = Instance.new("UICorner")
    deleteCorner.CornerRadius = UDim.new(1, 0)
    deleteCorner.Parent = deleteBtn
    
    deleteBtn.MouseButton1Click:Connect(function()
        savedChats[saveName] = nil
        savedItem:Destroy()
        task.wait(0.02)
        SavedScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, SavedUIListLayout.AbsoluteContentSize.Y + 10)
        addMessageToGui(nil, "🗑️ Deleted: " .. saveName, "SYSTEM")
    end)
    
    savedItem.MouseButton1Click:Connect(function()
        local success = pcall(function()
            setclipboard(savedChats[saveName])
        end)
        if success then
            addMessageToGui(nil, "✅ Copied: " .. saveName .. " to clipboard!", "SYSTEM")
        else
            addMessageToGui(nil, "❌ Failed to copy!", "SYSTEM")
        end
    end)
    
    task.wait(0.02)
    SavedScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, SavedUIListLayout.AbsoluteContentSize.Y + 10)
    
    addMessageToGui(nil, "💾 Saved: " .. saveName .. " (" .. count .. " messages)", "SYSTEM")
end

