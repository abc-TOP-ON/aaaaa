-- 7. كود تحريك الواجهة (محسن للهاتف)
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

-- للماوس
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- 8. دالة لجلب صورة اللاعب (مع تحسين للهاتف)
local function getPlayerAvatar(player)
    local userId = player.UserId
    local success, thumbnail = pcall(function()
        return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
    end)
    if success and thumbnail then
        return thumbnail
    else
        return nil
    end
end

-- 9. دالة لإنشاء صورة اللاعب (مكبرة للهاتف)
local function createAvatarImage(player)
    local ImageLabel = Instance.new("ImageLabel")
    ImageLabel.Size = UDim2.new(0, 40, 0, 40) -- أكبر للهاتف
    ImageLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    ImageLabel.BorderSizePixel = 0
    
    local ImageCorner = Instance.new("UICorner")
    ImageCorner.CornerRadius = UDim.new(1, 0)
    ImageCorner.Parent = ImageLabel
    
    local avatarUrl = getPlayerAvatar(player)
    if avatarUrl then
        ImageLabel.Image = avatarUrl
    else
        ImageLabel.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
    end
    
    return ImageLabel
end

-- 10. وظيفة إضافة الرسائل (بدون حد)
local function addMessageToGui(sender, messageText, isSearchResult)
    local MessageFrame = Instance.new("Frame")
    MessageFrame.Size = UDim2.new(1, -10, 0, 50) -- أكبر للهاتف
    MessageFrame.BackgroundTransparency = 1
    MessageFrame.Parent = ScrollingFrame
    
    -- صورة اللاعب (أكبر)
    local avatarImage = createAvatarImage(sender)
    avatarImage.Position = UDim2.new(0, 5, 0, 5)
    avatarImage.Parent = MessageFrame
    
    -- اسم اللاعب
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size = UDim2.new(0.8, 0, 0, 20)
    NameLabel.Position = UDim2.new(0, 50, 0, 2)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = sender.DisplayName or sender.Name
    NameLabel.TextColor3 = getPlayerColor(sender.Name)
    NameLabel.TextSize = 14
    NameLabel.Font = Enum.Font.SourceSansBold
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
    NameLabel.Parent = MessageFrame
    
    -- نص الرسالة (مع إمكانية اللف)
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(0.8, 0, 0, 24)
    TextLabel.Position = UDim2.new(0, 50, 0, 22)
    TextLabel.BackgroundTransparency = 1
    TextLabel.Text = messageText
    TextLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
    TextLabel.TextSize = 15
    TextLabel.Font = Enum.Font.SourceSans
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.TextWrapped = true
    TextLabel.TextScaled = false
    TextLabel.Parent = MessageFrame
    
    -- إذا كانت نتيجة بحث، نغير لون الخلفية
    if isSearchResult then
        MessageFrame.BackgroundColor3 = Color3.fromRGB(60, 40, 40)
        MessageFrame.BackgroundTransparency = 0.3
        local highlightCorner = Instance.new("UICorner")
        highlightCorner.CornerRadius = UDim.new(0, 8)
        highlightCorner.Parent = MessageFrame
    end
    
    -- تخزين الرسالة للبحث
    if not isSearchResult then
        table.insert(AllMessages, {
            player = sender,
            message = messageText,
            frame = MessageFrame:Clone()
        })
    end
    
    -- تحديث حجم الصندوق
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
    ScrollingFrame.CanvasPosition = Vector2.new(0, ScrollingFrame.CanvasSize.Y.Offset)
end

-- 11. دالة عرض الرسائل (العرض الطبيعي)
local function displayAllMessages()
    -- مسح كل الرسائل الحالية
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    -- إعادة عرض كل الرسائل المخزنة
    for _, data in ipairs(AllMessages) do
        local newFrame = data.frame:Clone()
        newFrame.Parent = ScrollingFrame
        newFrame.BackgroundTransparency = 1
    end
    
    task.wait(0.1)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
    ScrollingFrame.CanvasPosition = Vector2.new(0, ScrollingFrame.CanvasSize.Y.Offset)
end

-- 12. وظيفة البحث
local function searchMessages(searchText)
    -- مسح الرسائل الحالية
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    if searchText == "" then
        -- الرجوع للقائمة الرئيسية
        isSearching = false
        BackButton.Visible = false
        SearchBox.PlaceholderText = "🔍 ابحث عن كلمة..."
        displayAllMessages()
        return
    end
    
    -- تفعيل وضع البحث
    isSearching = true
    BackButton.Visible = true
    SearchBox.PlaceholderText = "🔍 جاري البحث..."
    
    local found = false
    local searchLower = string.lower(searchText)
    
    -- البحث من الأحدث للأقدم
    for i = #AllMessages, 1, -1 do
        local data = AllMessages[i]
        if string.find(string.lower(data.message), searchLower) then
            found = true
            -- نضيف الرسالة مع تمييز
            local MessageFrame = Instance.new("Frame")
            MessageFrame.Size = UDim2.new(1, -10, 0, 50)
            MessageFrame.BackgroundColor3 = Color3.fromRGB(60, 40, 40)
            MessageFrame.BackgroundTransparency = 0.3
            MessageFrame.Parent = ScrollingFrame
            
            local highlightCorner = Instance.new("UICorner")
            highlightCorner.CornerRadius = UDim.new(0, 8)
            highlightCorner.Parent = MessageFrame
            
            -- صورة اللاعب
            local avatarImage = createAvatarImage(data.player)
            avatarImage.Position = UDim2.new(0, 5, 0, 5)
            avatarImage.Parent = MessageFrame
            
            -- اسم اللاعب
            local NameLabel = Instance.new("TextLabel")
            NameLabel.Size = UDim2.new(0.8, 0, 0, 20)
            NameLabel.Position = UDim2.new(0, 50, 0, 2)
            NameLabel.BackgroundTransparency = 1
            NameLabel.Text = data.player.DisplayName or data.player.Name
            NameLabel.TextColor3 = getPlayerColor(data.player.Name)
            NameLabel.TextSize = 14
            NameLabel.Font = Enum.Font.SourceSansBold
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left
            NameLabel.Parent = MessageFrame
            
            -- نص الرسالة
            local TextLabel = Instance.new("TextLabel")
            TextLabel.Size = UDim2.new(0.8, 0, 0, 24)
            TextLabel.Position = UDim2.new(0, 50, 0, 22)
            TextLabel.BackgroundTransparency = 1
            TextLabel.Text = data.message
            TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            TextLabel.TextSize = 15
            TextLabel.Font = Enum.Font.SourceSans
            TextLabel.TextXAlignment = Enum.TextXAlignment.Left
            TextLabel.TextWrapped = true
            TextLabel.Parent = MessageFrame
        end
    end
    
    if not found then
        local noResult = Instance.new("TextLabel")
        noResult.Size = UDim2.new(1, 0, 0, 40)
        noResult.Position = UDim2.new(0, 0, 0, 20)
        noResult.BackgroundTransparency = 1
        noResult.Text = "❌ لا توجد رسائل تحتوي على: " .. searchText
        noResult.TextColor3 = Color3.fromRGB(200, 100, 100)
        noResult.TextSize = 16
        noResult.Font = Enum.Font.SourceSans
        noResult.TextXAlignment = Enum.TextXAlignment.Center
        noResult.Parent = ScrollingFrame
    end
    
    task.wait(0.1)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

