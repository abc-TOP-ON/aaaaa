    pcall(function()
        local sound = Instance.new("Sound")
        sound.SoundId = SoundId
        sound.Volume = Settings.NightcoreMode and 0.5 or 0.3
        sound.PlaybackSpeed = Settings.NightcoreMode and 1.5 or 1
        sound.Parent = MainFrame
        sound:Play()
        task.wait(0.5)
        sound:Destroy()
    end)
end

local function updateStats(player, message)
    if not Settings.TypingSpeedEnabled and not Settings.ActivityRewards then return end
    
    if not PlayerStats[player.Name] then
        PlayerStats[player.Name] = {
            messages = 0,
            words = 0,
            characters = 0,
            lastMessage = tick(),
            totalTime = 0,
            points = 0
        }
    end
    
    local stats = PlayerStats[player.Name]
    stats.messages = stats.messages + 1
    stats.words = stats.words + #string.split(message, " ")
    stats.characters = stats.characters + #message
    
    if Settings.TypingSpeedEnabled then
        local timeDiff = tick() - stats.lastMessage
        if timeDiff > 0 then
            stats.totalTime = stats.totalTime + timeDiff
        end
        stats.lastMessage = tick()
    end
    
    if Settings.ActivityRewards then
        stats.points = stats.points + 1
        if stats.points % 10 == 0 then
            addSystemMessage("🏆 " .. player.Name .. " earned 10 activity points! Total: " .. stats.points)
        end
    end
end

local function updateChatMap(sender, target)
    if not Settings.ChatMapEnabled then return end
    
    if not ChatMap[sender.Name] then
        ChatMap[sender.Name] = {}
    end
    if not ChatMap[sender.Name][target] then
        ChatMap[sender.Name][target] = 0
    end
    ChatMap[sender.Name][target] = ChatMap[sender.Name][target] + 1
end

local function detectPattern(player, message)
    if not Settings.PatternDetection then return end
    
    if not PlayerStats[player.Name] then
        PlayerStats[player.Name] = {patterns = {}}
    end
    
    local words = string.split(message, " ")
    for _, word in ipairs(words) do
        if #word > 3 then
            if not PlayerStats[player.Name].patterns[word] then
                PlayerStats[player.Name].patterns[word] = 0
            end
            PlayerStats[player.Name].patterns[word] = PlayerStats[player.Name].patterns[word] + 1
            
            if PlayerStats[player.Name].patterns[word] >= 5 then
                addSystemMessage("⚠️ Pattern detected: " .. player.Name .. " repeats '" .. word .. "'")
                PlayerStats[player.Name].patterns[word] = 0
            end
        end
    end
end

local function detectEmotion(message)
    if not Settings.EmotionDetection then return end
    
    local emojis = {
        ["😊"] = "happy",
        ["😢"] = "sad",
        ["😡"] = "angry",
        ["😂"] = "happy",
        ["😍"] = "love",
        ["😭"] = "sad",
        ["🤣"] = "happy",
        ["💔"] = "sad",
    }
    
    for emoji, emotion in pairs(emojis) do
        if string.find(message, emoji) then
            if not EmotionData[emotion] then
                EmotionData[emotion] = 0
            end
            EmotionData[emotion] = EmotionData[emotion] + 1
        end
    end
end

local function handleAutoReply(player, message)
    if not Settings.AutoReplyEnabled then return end
    
    local lowerMessage = string.lower(message)
    for keyword, response in pairs(Settings.AutoReplyMessages) do
        if string.find(lowerMessage, string.lower(keyword)) then
            task.wait(0.5)
            TextChatService:SendAsync(response)
            addSystemMessage("🤖 Auto-reply sent to " .. player.Name)
            break
        end
    end
end

local function handleAIAssistant(player, message)
    if not Settings.AIAssistant then return end
    
    local lowerMessage = string.lower(message)
    for keyword, response in pairs(AIResponses) do
        if string.find(lowerMessage, keyword) then
            task.wait(0.5)
            TextChatService:SendAsync(response)
            addSystemMessage("🤖 AI Assistant replied to " .. player.Name)
            break
        end
    end
end

