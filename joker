local function getSmartGradient()
    local hour = os.date("*t").hour
    local colors
    if hour >= 6 and hour < 12 then
        -- الصباح
        colors = {
            ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 10, 30)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(30, 20, 50)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 30, 40))
        }
    elseif hour >= 12 and hour < 18 then
        -- الظهر
        colors = {
            ColorSequenceKeypoint.new(0, Color3.fromRGB(10, 5, 25)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(25, 10, 40)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 20, 50))
        }
    else
        -- الليل
        colors = {
            ColorSequenceKeypoint.new(0, Color3.fromRGB(5, 5, 15)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(15, 5, 25)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 5, 20))
        }
    end
    return ColorSequence.new(colors)
end

local gradient = Instance.new("UIGradient")
