local soundPool = {}

local function playSound()
    if not Settings.SoundEnabled or Settings.DNDMode then return end
    
    local sound = table.remove(soundPool)
    if not sound then
        sound = Instance.new("Sound")
        sound.SoundId = SoundId
    end
    
    sound.Volume = Settings.NightcoreMode and 0.5 or 0.3
    sound.PlaybackSpeed = Settings.NightcoreMode and 1.5 or 1
    sound.Parent = MainFrame
    sound:Play()
    
    task.delay(0.5, function()
        sound:Stop()
        sound.Parent = nil
        table.insert(soundPool, sound)
    end)
end

-- ================================================================
--                    STATS SYSTEM (Optimized)
-- ================================================================
local function updateStats(player, message)
    if not Settings.TypingSpeedEnabled and not Settings.ActivityRewards then return end
    
    local name = player.Name
    if not Cache.Stats[name] then
        Cache.Stats[name] = {
            messages = 0,
            words = 0,
            chars = 0,
            lastTime = tick(),
            points = 0,
        }
    end
    
    local stats = Cache.Stats[name]
    stats.messages = stats.messages + 1
    stats.words = stats.words + #string.split(message, " ")
    stats.chars = stats.chars + #message
    
    if Settings.ActivityRewards then
        stats.points = stats.points + 1
        if stats.points % 10 == 0 then
            addSystemMessage("🏆 " .. player.Name .. " earned 10 points! Total: " .. stats.points)
        end
    end
end

