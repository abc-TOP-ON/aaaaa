-- 14. ربط نظام الشات
local function handleMessage(player, message)
    if player and message and message ~= "" then
        addMessageToGui(player, message, false)
        -- إذا كان في وضع البحث، نحدث النتائج تلقائياً
        if isSearching and SearchBox.Text ~= "" then
            searchMessages(SearchBox.Text)
        end
    end
end

if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(textMessage)
        local source = textMessage.TextSource
        if source then
            local sender = Players:GetPlayerByUserId(source.UserId)
            if sender and sender ~= LocalPlayer then
                handleMessage(sender, textMessage.Text)
            end
        end
    end)
else
    local function hookPlayer(player)
        if player ~= LocalPlayer then
            player.Chatted:Connect(function(message)
                handleMessage(player, message)
            end)
        end
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        hookPlayer(player)
    end
    Players.PlayerAdded:Connect(hookPlayer)
end

