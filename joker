            SavedScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, SavedUIListLayout.AbsoluteContentSize.Y + 10)
        end
    end)

    SettingsBtn.MouseButton1Click:Connect(function()
        SettingsFrame.Visible = not SettingsFrame.Visible
        if SettingsFrame.Visible then
            task.wait(0.02)
            SettingsScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, SettingsUIListLayout.AbsoluteContentSize.Y + 20)
        end
    end)

    ClearBtn.MouseButton1Click:Connect(function()
        for _, item in ipairs(ScrollingFrame:GetChildren()) do
            if item:IsA("Frame") then
                item:Destroy()
            end
        end
        ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        autoScroll = true
        addMessageToGui(nil, "🗑️ Chat log cleared!", "SYSTEM")
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        uiVisible = false
        MainFrame.Visible = false
        stopSpyParticles()
    end)

    SettingsCloseBtn.MouseButton1Click:Connect(function()
        SettingsFrame.Visible = false
    end)

    SavedCloseBtn.MouseButton1Click:Connect(function()
        SavedFrame.Visible = false
    end)

    ClearSavedBtn.MouseButton1Click:Connect(function()
        for _, item in ipairs(SavedScrollingFrame:GetChildren()) do
            if item:IsA("TextButton") then
                item:Destroy()
            end
        end
        savedChats = {}
        savedChatsCount = 0
        SavedScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        addMessageToGui(nil, "🗑️ All saved chats cleared!", "SYSTEM")
    end)

    -- ============================================
    -- زر ABC (فتح/إغلاق)
    -- ============================================
    local uiVisible = false

    ABCToggle.MouseButton1Click:Connect(function()
        uiVisible = not uiVisible
        MainFrame.Visible = uiVisible
        
        if uiVisible then
            startSpyParticles()
            task.wait(0.1)
            ScrollingFrame.CanvasPosition = Vector2.new(0, ScrollingFrame.CanvasSize.Y.Offset)
        else
            stopSpyParticles()
            for _, child in pairs(MainFrame:GetChildren()) do
                if child:IsA("Frame") and child ~= TitleBar and child ~= SearchBox and child ~= ScrollingFrame then
                    local corner = child:FindFirstChildOfClass("UICorner")
                    if corner and child.Size.X.Offset < 10 then
                        child:Destroy()
                    end
                end
            end
        end
    end)

    -- رسالة ترحيب
    addMessageToGui(nil, "ABC Spy Pro v1.0 activated with ALL features!", "SYSTEM")
    addMessageToGui(nil, "💾 Save | 📁 Saved | ⚙️ Settings (29 options)", "SYSTEM")
    
end)
