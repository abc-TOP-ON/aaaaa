local isLoadingComplete = false
local loadStartTime = os.clock()
local totalLoadTime = 0

for _, task in ipairs(tasks) do
    totalLoadTime = totalLoadTime + task.time
end

-- تشغيل المهام
task.spawn(function()
    for i, task in ipairs(tasks) do
        task.wait(task.time * 0.6)
        if not isLoadingComplete then
            StatusText.Text = "⏳ " .. task.name .. "..."
            showAdvancedNotification(task.name, task.icon, task.color)
        end
    end
end)

-- تحديث شريط التحميل
local loadTween = TweenService:Create(LoadingBarFill, TweenInfo.new(totalLoadTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
    Size = UDim2.new(1, 0, 1, 0)
})
loadTween:Play()

-- تحديث الإحصائيات
local speedSamples = {}
local lastProgress = 0
local lastTime = os.clock()

local connection
connection = RunService.RenderStepped:Connect(function()
    local elapsed = os.clock() - loadStartTime
    local progress = math.clamp(elapsed / totalLoadTime, 0, 1)
    local smoothProgress = progress * (2 - progress)
    
    -- تحديث النسبة
    local percent = math.floor(smoothProgress * 100)
    PercentageText.Text = percent .. "%"
    
    -- تحديث المؤقت
    local seconds = math.floor(elapsed)
    local minutes = math.floor(seconds / 60)
    seconds = seconds % 60
    TimerText.Text = string.format("⏱ %02d:%02d", minutes, seconds)
    
    -- حساب السرعة
    local timeDiff = os.clock() - lastTime
    if timeDiff > 0.1 then
        local speed = (smoothProgress - lastProgress) / timeDiff * 100
        table.insert(speedSamples, speed)
        if #speedSamples > 10 then table.remove(speedSamples, 1) end
        
        local avgSpeed = 0
        for _, s in ipairs(speedSamples) do
            avgSpeed = avgSpeed + s
        end
        avgSpeed = avgSpeed / #speedSamples
        
        SpeedText.Text = string.format("⚡ Speed: %.1f MB/s", avgSpeed)
        lastProgress = smoothProgress
        lastTime = os.clock()
    end
    
    -- تحديث التموج
    ripple.Position = UDim2.new(smoothProgress, 0, 0, 0)
    
    if progress >= 1 then
        connection:Disconnect()
    end
end)

loadTween.Completed:Wait()
task.wait(0.5)
isLoadingComplete = true

StatusText.Text = "✅ COMPLETED SUCCESSFULLY!"
StatusText.TextColor3 = Color3.fromRGB(50, 255, 100)
