-- ============================================================
--                      UTILITY FUNCTIONS
-- ============================================================

local function getPlayerColor(playerName)
    if not PlayerColors[playerName] then
        local hue = math.random()
        PlayerColors[playerName] = Color3.fromHSV(hue, 0.7, 0.8)
    end
    return PlayerColors[playerName]
end

local function isFiltered(message)
    for _, word in ipairs(Settings.FilteredWords) do
        if string.find(string.lower(message), string.lower(word)) then
            return true
        end
    end
    return false
end

local function isBadWord(message)
    if not Settings.BadWordFilter then return false end
    for _, word in ipairs(Settings.BadWords) do
        if string.find(string.lower(message), string.lower(word)) then
            return true
        end
    end
    return false
end

local function containsLink(message)
    return string.find(string.lower(message), "http") or 
           string.find(string.lower(message), ".com") or
           string.find(string.lower(message), ".net")
end

local function containsCrypto(message)
    local crypto = {"bitcoin", "btc", "ethereum", "eth", "dogecoin", "doge", "wallet", "send", "transfer"}
    for _, word in ipairs(crypto) do
        if string.find(string.lower(message), word) then
            return true
        end
    end
    return false
end

local function containsMention(message)
    return string.find(string.lower(message), string.lower(Settings.MyName))
end

local function translateMessage(message)
    local translations = {
        ["hello"] = "مرحبا",
        ["goodbye"] = "مع السلامة",
        ["thanks"] = "شكراً",
        ["thank you"] = "شكراً لك",
        ["yes"] = "نعم",
        ["no"] = "لا",
        ["how are you"] = "كيف حالك؟",
        ["what"] = "ماذا؟",
        ["who"] = "من؟",
        ["where"] = "أين؟",
        ["why"] = "لماذا؟",
        ["when"] = "متى؟",
        ["game"] = "لعبة",
        ["play"] = "العب",
        ["help"] = "مساعدة",
        ["friend"] = "صديق",
        ["love"] = "حب",
        ["hate"] = "كره",
        ["good"] = "جيد",
        ["bad"] = "سيء",
        ["nice"] = "جميل",
        ["cool"] = "رائع",
        ["awesome"] = "مذهل",
    }
    for eng, arb in pairs(translations) do
        if string.find(string.lower(message), eng) then
            return string.gsub(message, eng, arb)
        end
    end
    return message
end

