-- Make Exit Button Draggable
local exitDragging, exitDragInput, exitDragStart, exitStartPos

ExitFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        exitDragging = true
        exitDragStart = input.Position
        exitStartPos = ExitFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                exitDragging = false
            end
        end)
    end
end)

ExitFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        exitDragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == exitDragInput and exitDragging then
        local delta = input.Position - exitDragStart
        ExitFrame.Position = UDim2.new(
            exitStartPos.X.Scale,
            exitStartPos.X.Offset + delta.X,
            exitStartPos.Y.Scale,
            exitStartPos.Y.Offset + delta.Y
        )
    end
end)

