local function addSystemMessage(text)
    local fakePlayer = {
        Name = "System",
        DisplayName = "⚙️ System",
        UserId = 0
    }
    addMessageToGui(fakePlayer, text, false)
end

function addMessageToGui(sender, messageText, isSearchResult)
    -- Fast filters
    if isFiltered(messageText) then return end
    if Settings.BadWordFilter and isBadWord(messageText) then return end
    if sender == LocalPlayer and not Settings.ShowMyMessages then return end
    
    -- Link detection
    if Settings.LinkAlert and containsLink(messageText) and sender ~= LocalPlayer then
        addSystemMessage("⚠️ Link from " .. sender.Name .. ": " .. messageText)
    end
    
    -- Crypto detection
    if Settings.CryptoScamDetection and containsCrypto(messageText) and sender ~= LocalPlayer then
        addSystemMessage("🚨 CRYPTO SCAM ALERT: " .. sender.Name)
    end
    
    -- Mention detection
    if Settings.MentionAlert and containsMention(messageText) and sender ~= LocalPlayer then
        task.spawn(function()
            for i = 1, 3 do
                MainFrame.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
                task.wait(0.08)
                MainFrame.BackgroundColor3 = Settings.DarkMode and Color3.fromRGB(20, 20, 30) or Color3.fromRGB(240, 240, 245)
                task.wait(0.08)
            end
        end)
        playSound()
        addSystemMessage("🔔 " .. sender.Name .. " mentioned you!")
    end
    
    -- Update stats
    updateStats(sender, messageText)
    
    -- Store message
    local messageData = {
        player = sender,
        message = messageText,
        time = tick(),
    }
    
    table.insert(Cache.Messages, messageData)
    
    -- Limit messages
    if #Cache.Messages > PERFORMANCE.MAX_MESSAGES then
        table.remove(Cache.Messages, 1)
    end
    
    -- Play sound
    if sender ~= LocalPlayer then
        playSound()
    end
    
    -- Show notification
    if sender ~= LocalPlayer then
        showNotification(sender, messageText)
    end
    
    -- Render if not searching
    if not isSearching then
        renderAllMessages()
    end
end

-- ================================================================
--                    SEARCH (Optimized Binary Search)
-- ================================================================
local searchResults = {}

local function binarySearchMessages(query)
    local results = {}
    local lowerQuery = string.lower(query)
    
    -- Use cached messages for faster search
    for i = #Cache.Messages, 1, -1 do
        local data = Cache.Messages[i]
        if fastStringFind(data.message, lowerQuery) then
            table.insert(results, data)
            if #results >= PERFORMANCE.MAX_SEARCH_RESULTS then
                break
            end
        end
    end
    
    return results
end

function searchMessages(searchText)
    -- Clear current messages
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    if searchText == "" then
        isSearching = false
        BackButton.Visible = false
        SearchBox.PlaceholderText = "🔍 Search..."
        renderAllMessages()
        return
    end
    
    isSearching = true
    BackButton.Visible = true
    SearchBox.PlaceholderText = "🔍 Searching..."
    
    local results = binarySearchMessages(searchText)
    
    if #results > 0 then
        for i = 1, #results do
            local data = results[i]
            local frame = createMessageUI(data.player, data.message, true)
            frame.Parent = ScrollingFrame
        end
        addSystemMessage("🔍 Found " .. #results .. " results for '" .. searchText .. "'")
    else
        local noResult = Instance.new("TextLabel")
        noResult.Size = UDim2.new(1, 0, 0, 40)
        noResult.Position = UDim2.new(0, 0, 0, 20)
        noResult.BackgroundTransparency = 1
        noResult.Text = "❌ No messages found: " .. searchText
        noResult.TextColor3 = Color3.fromRGB(200, 100, 100)
        noResult.TextSize = 16
        noResult.Font = Enum.Font.SourceSans
        noResult.TextXAlignment = Enum.TextXAlignment.Center
        noResult.Parent = ScrollingFrame
    end
    
    task.wait(0.05)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

