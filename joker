-- نظام الجزيئات الكمومية (Quantum Particles)
-- ============================================================
local quantumParticles = {}

local function createQuantumParticle()
    local particle = Instance.new("Frame")
    local size = math.random(1, 8)
    particle.Size = UDim2.new(0, size, 0, size)
    particle.Position = UDim2.new(math.random(), 0, math.random(), 0)
    
    -- ألوان كمومية (تتغير بسرعة)
    local hue = math.random()
    local color = Color3.fromHSV(hue, 1, 1)
    particle.BackgroundColor3 = color
    particle.BackgroundTransparency = math.random(3, 7) / 10
    particle.BorderSizePixel = 0
    particle.Parent = Background
    
    -- تأثير الهالة الكمومية
    local aura = Instance.new("UIStroke")
    aura.Color = color
    aura.Thickness = 3
    aura.Transparency = 0.8
    aura.Parent = particle
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = particle
    
    -- حركة كمومية (عشوائية بالكامل)
    local speed = math.random(3, 10)
    local pathCount = math.random(3, 6)
    local currentPath = 1
    
    local function createQuantumPath()
        local targetX = math.random()
        local targetY = math.random()
        local duration = speed / math.random(2, 5)
        
        local tween = TweenService:Create(particle, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Position = UDim2.new(targetX, 0, targetY, 0),
            BackgroundColor3 = Color3.fromHSV(math.random(), 1, 1),
            Size = UDim2.new(0, math.random(1, 8), 0, math.random(1, 8))
        })
        
        tween:Play()
        tween.Completed:Connect(function()
            currentPath = currentPath + 1
            if currentPath <= pathCount then
                createQuantumPath()
            else
                particle:Destroy()
            end
        end)
    end
    
    createQuantumPath()
    table.insert(quantumParticles, particle)
end

local quantumLoop = task.spawn(function()
    while task.wait(0.03) do
        for i = 1, math.random(2, 6) do
            createQuantumParticle()
        end
        if #quantumParticles > CONFIG.ParticleCount then
            for i = 1, 30 do
                local p = quantumParticles[1]
                if p then p:Destroy() end
                table.remove(quantumParticles, 1)
            end
        end
    end
end)

