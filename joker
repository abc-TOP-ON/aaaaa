    -- Message Text
    local TextLabel = getFromPool("TextLabels", function()
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.8, 0, 0, 24)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.SourceSans
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextWrapped = true
        return label
    end)
    
    local displayText = messageText
    if Settings.VoiceTranslation then
        -- Fast translation lookup
        local translated = Cache.Translations[messageText]
        if translated then
            displayText = translated
        end
    end
    
    TextLabel.Position = UDim2.new(0, 50, 0, 22)
    TextLabel.Text = displayText
    TextLabel.TextColor3 = Color3.fromRGB(230, 230, 240)
