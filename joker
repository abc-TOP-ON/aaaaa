-- ============================================================
-- نظام التحميل الرئيسي
-- ============================================================
local isLoadingComplete = false
local loadStartTime = os.clock()
local totalLoadTime = 0

for _, task in ipairs(tasks) do
    totalLoadTime = totalLoadTime + task.time
end

-- تشغيل المهام
task.spawn(function()
    for i, task in ipairs(tasks) do
        task.wait(task.time * 0.6)
        if not isLoadingComplete then
            StatusText.Text = "⟳ " .. task.name .. "..."
            showNotification(task.name, task.color)
        end
    end
end)

-- تحديث شريط التحميل
local loadTween = TweenService:Create(LoadingBarFill, TweenInfo.new(totalLoadTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
    Size = UDim2.new(1, 0, 1, 0)
})
loadTween:Play()

-- تحديث النسبة
local connection
connection = RunService.RenderStepped:Connect(function()
    local elapsed = os.clock() - loadStartTime
    local progress = math.clamp(elapsed / totalLoadTime, 0, 1)
    local smoothProgress = progress * (2 - progress)
    
    PercentageText.Text = math.floor(smoothProgress * 100) .. "%"
    
    if progress >= 1 then
        connection:Disconnect()
    end
end)

loadTween.Completed:Wait()
task.wait(0.4)
isLoadingComplete = true

StatusText.Text = "✓ COMPLETED!"
StatusText.TextColor3 = Color3.fromRGB(50, 255, 100)
showNotification("✅ Complete!", Color3.fromRGB(50, 255, 100))

task.wait(0.6)

-- ============================================================
-- إخفاء الواجهة
-- ============================================================
local function destroyScreen()
    task.cancel(particleLoop)
    
    for _, p in pairs(particles) do
        p:Destroy()
    end
    particles = {}
    
    local fadeInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    
    for _, item in pairs(Background:GetChildren()) do
        task.spawn(function()
            pcall(function()
                if item:IsA("TextLabel") then
                    TweenService:Create(item, fadeInfo, {TextTransparency = 1}):Play()
                elseif item:IsA("ImageLabel") then
                    TweenService:Create(item, fadeInfo, {ImageTransparency = 1}):Play()
                elseif item:IsA("Frame") and item ~= Background then
                    TweenService:Create(item, fadeInfo, {BackgroundTransparency = 1}):Play()
                end
                
                local stroke = item:FindFirstChildOfClass("UIStroke")
                if stroke then
                    TweenService:Create(stroke, fadeInfo, {Transparency = 1}):Play()
                end
            end)
        end)
    end
    
    local fadeBackground = TweenService:Create(Background, fadeInfo, {BackgroundTransparency = 1})
    fadeBackground:Play()
    fadeBackground.Completed:Wait()
    
    pcall(function()
        ScreenGui:Destroy()
    end)
    
    print("✅ ABC Mobile Loading Screen Destroyed!")
end

destroyScreen()

-- ============================================================
-- حماية خفيفة
-- ============================================================
local cancelAttempts = 0
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Escape then
        if not isLoadingComplete then
            cancelAttempts = cancelAttempts + 1
            if cancelAttempts >= 3 then
                isLoadingComplete = true
                task.cancel(particleLoop)
                pcall(function() ScreenGui:Destroy() end)
                print("⏹ Loading cancelled")
            else
                showNotification("ESC " .. (3 - cancelAttempts) .. " more", Color3.fromRGB(255, 200, 50))
            end
        end
    end
end)

print("📱 ABC Premium Mobile Loading Screen Loaded!")
print("✨ Welcome, " .. LocalPlayer.Name .. "!")
