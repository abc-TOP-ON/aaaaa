--                    SEARCH
-- ================================================================
local isSearching = false

function searchMessages(searchText)
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    if searchText == "" then
        isSearching = false
        BackBtn.Visible = false
        SearchBox.PlaceholderText = "Search messages..."
        renderAllMessages()
        return
    end
    
    isSearching = true
    BackBtn.Visible = true
    SearchBox.PlaceholderText = "Searching..."
    
    local found = false
    local lowerQuery = string.lower(searchText)
    
    for i = #Cache.Messages, 1, -1 do
        local data = Cache.Messages[i]
        if fastStringFind(data.message, lowerQuery) then
            found = true
            local frame = createMessageUI(data.player, data.message, true)
            frame.Parent = ScrollingFrame
        end
    end
    
    if not found then
        local noResult = Instance.new("TextLabel")
        noResult.Size = UDim2.new(1, 0, 0, 40)
        noResult.Position = UDim2.new(0, 0, 0, 20)
        noResult.BackgroundTransparency = 1
        noResult.Text = "🔍 No results for '" .. searchText .. "'"
        noResult.TextColor3 = DESIGN.Text2
        noResult.TextSize = 14
        noResult.Font = Enum.Font.Gotham
        noResult.TextXAlignment = Enum.TextXAlignment.Center
        noResult.Parent = ScrollingFrame
    end
    
    task.wait(0.05)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

