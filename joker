function playSound()
    if not Settings.SoundEnabled or Settings.DNDMode then return end
    
    local sound = table.remove(soundPool)
    if not sound then
        sound = Instance.new("Sound")
        sound.SoundId = SoundId
    end
    
    sound.Volume = Settings.NightcoreMode and 0.5 or 0.3
    sound.PlaybackSpeed = Settings.NightcoreMode and 1.5 or 1
    sound.Parent = MainFrame
    sound:Play()
    
    task.delay(0.5, function()
        sound:Stop()
        sound.Parent = nil
        table.insert(soundPool, sound)
    end)
end

