local function createParticle()
    local particle = Instance.new("Frame")
    local size = math.random(2, 5)
    particle.Size = UDim2.new(0, size, 0, size)
    particle.Position = UDim2.new(math.random(), 0, math.random(), 0)
    
    local colors = {
        Color3.fromRGB(138, 43, 226),
        Color3.fromRGB(160, 50, 255),
        Color3.fromRGB(180, 80, 255),
        Color3.fromRGB(120, 30, 200)
    }
    particle.BackgroundColor3 = colors[math.random(1, #colors)]
    particle.BackgroundTransparency = math.random(2, 6) / 10
    particle.BorderSizePixel = 0
    particle.Parent = MainFrame
    
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(1, 0)
    UICorner.Parent = particle

    local speed = math.random(5, 15)
    local targetX = particle.Position.X.Scale + math.random(-30, 30) / 100
    local targetY = particle.Position.Y.Scale + math.random(-30, 30) / 100
    
    targetX = math.clamp(targetX, 0, 1)
    targetY = math.clamp(targetY, 0, 1)
    
    local tween = TweenService:Create(particle, TweenInfo.new(speed, Enum.EasingStyle.Linear), {
        Position = UDim2.new(targetX, 0, targetY, 0),
        BackgroundTransparency = 1
    })
    tween:Play()
    tween.Completed:Connect(function() particle:Destroy() end)
end

local particleLoop
local function startParticles()
    if particleLoop then return end
    particleLoop = task.spawn(function()
        while MainFrame.Visible do
            createParticle()
            if math.random(1, 2) == 1 then
                createParticle()
            end
            task.wait(0.08)
        end
    end)
end

local function stopParticles()
    if particleLoop then
        task.cancel(particleLoop)
        particleLoop = nil
    end
end

