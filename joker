local particles = {}
local particleConnections = {}

local function create3DParticle()
    local particle = Instance.new("Frame")
    local size = math.random(2, 7)
    particle.Size = UDim2.new(0, size, 0, size)
    particle.Position = UDim2.new(math.random(), 0, -0.1, 0)
    
    -- ألوان قوس قزح متحركة
    local hue = math.random() 
    local color = Color3.fromHSV(hue, 1, 1)
    particle.BackgroundColor3 = color
    particle.BackgroundTransparency = math.random(2, 6) / 10
    particle.BorderSizePixel = 0
    particle.Parent = Background
    
    -- تأثير توهج مزدوج
    local glow1 = Instance.new("UIStroke")
    glow1.Color = color
    glow1.Thickness = 2
    glow1.Transparency = 0.7
    glow1.Parent = particle
    
    local glow2 = Instance.new("UIStroke")
    glow2.Color = Color3.fromRGB(255, 255, 255)
    glow2.Thickness = 1
    glow2.Transparency = 0.9
    glow2.Parent = particle
    
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(1, 0)
    UICorner.Parent = particle

    -- مسار 3D مع حركة متعرجة
    local speed = math.random(5, 12)
    local xOffset = math.random(-200, 200) / 1000
    local zOffset = math.random(-100, 100) / 1000
    
    local path1 = TweenService:Create(particle, TweenInfo.new(speed * 0.4, Enum.EasingStyle.Quad), {
        Position = UDim2.new(particle.Position.X.Scale + xOffset, 0, 0.4 + zOffset, 0),
        Size = UDim2.new(0, size * 1.5, 0, size * 1.5)
    })
    local path2 = TweenService:Create(particle, TweenInfo.new(speed * 0.3, Enum.EasingStyle.Quad), {
        Position = UDim2.new(particle.Position.X.Scale + xOffset * 1.5, 0, 0.7 + zOffset, 0)
    })
    local path3 = TweenService:Create(particle, TweenInfo.new(speed * 0.3, Enum.EasingStyle.Quad), {
        Position = UDim2.new(particle.Position.X.Scale + xOffset * 2, 0, 1.2, 0),
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 0, 0, 0)
    })
    
    path1:Play()
    path1.Completed:Connect(function() path2:Play() end)
    path2.Completed:Connect(function() path3:Play() end)
    path3.Completed:Connect(function() 
        particle:Destroy() 
    end)
    
    table.insert(particles, particle)
end

local particleLoop = task.spawn(function()
    while task.wait(0.05) do
        for i = 1, math.random(2, 5) do
            create3DParticle()
        end
        if #particles > CONFIG.ParticleCount then
            for i = 1, 30 do
                local p = particles[1]
                if p then p:Destroy() end
                table.remove(particles, 1)
            end
        end
    end
end)

